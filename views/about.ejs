<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<style>
    body {
        background: linear-gradient(-45deg, #4e73df, #1cc88a, #36b9cc, #6610f2);
        background-size: 400% 400%;
        animation: gradientBG 10s ease infinite;
        color: #fff;
        padding-top: 90px;
    }

    @keyframes gradientBG {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed;
        top: 110px;
        left: 20px;
        width: 220px;
        backdrop-filter: blur(15px);
        background: rgba(0, 0, 0, 0.3);
        padding: 20px;
        border-radius: 15px;
    }

    .sidebar h3 {
        text-align: center;
        margin-bottom: 15px;
    }

    .sidebar ul {
        list-style: none;
    }

    .sidebar ul li {
        margin: 12px 0;
    }

    .sidebar ul li a {
        text-decoration: none;
        color: #fff;
        transition: 0.3s;
    }

    .sidebar ul li a:hover {
        color: #ffdd57;
        padding-left: 5px;
    }

    /* SECTIONS */
    section {
        padding: 70px 15% 70px 22%;
    }

    .hero {
        text-align: center;
    }

    .section-title {
        text-align: center;
        font-size: 30px;
        margin-bottom: 25px;
    }

    .card {
        backdrop-filter: blur(15px);
        background: rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 40px;
        margin-top: 40px;
        display: flex;
        gap: 30px;
        align-items: center;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        opacity: 0;
        transform: translateY(50px);
        transition: 0.6s;
    }

    .card img {
        width: 230px;
        height: 300px;
        border-radius: 20px;
        object-fit: cover;
        border: 4px solid rgba(255, 255, 255, 0.3);
    }

    .content {
        flex: 1;
    }

    .content p {
        margin-bottom: 8px;
        line-height: 1.6;
    }

    .highlight {
        color: #ffdd57;
        font-weight: 600;
    }

    /* MOBILE */
    @media (max-width: 992px) {
        .sidebar { display: none; }
        section { padding: 70px 10%; }
        .card { flex-direction: column; text-align: center; }
        .card img { width: 180px; height: 180px; }
    }
</style>

<body class="d-flex flex-column min-vh-100">
    <%- include('partials/navbar') %>
    <%- include('partials/flash') %>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h3>Sections</h3>
        <ul>
            <li><a href="#hero">Welcome</a></li>
            <li><a href="#about">About Arise</a></li>
            <li><a href="#founder">Founder</a></li>
            <li><a href="#frontend">Front-End Developer</a></li>
            <li><a href="#backend">Back-End Developer</a></li>
        </ul>
    </div>

    <section class="hero" id="hero">
        <h1>Welcome to Arise</h1>
        <p>Empowering education with innovation, accessibility, and excellence.</p>
    </section>

    <section id="about">
        <h2 class="section-title">About Arise</h2>
        <div class="card">
            <div class="content">
                <p>
                    <span class="highlight">Arise</span> is a next-generation
                    e-learning platform designed to make education interactive,
                    accessible, and future-ready.
                </p>
                <p>We offer expert-led live classes, real-time faculty interaction, and instant doubt-solving.</p>
                <p>With smart digital tools and performance tracking, Arise creates a personalized learning experience anytime, anywhere.</p>
            </div>
        </div>
    </section>

    <section id="founder">
        <h2 class="section-title">Founder</h2>
        <div class="card">
            <img src="/images/image.png" alt="Founder"> <!-- Using a placeholder image from uploads if original not found -->
            <div class="content">
                <h2>Mr. Bishal Debnath</h2>
                <p class="highlight">Assistant Professor | Applied Science & Humanities</p>
                <p><strong>Education:</strong> B.A., M.A., Ph.D Course Work, UGC NET, B.Ed, CTET, DITA | DFAS</p>
                <p><strong>Teaching Experience:</strong> 2 Years</p>
                <p><strong>Specialization:</strong> English Literature</p>
                <p>Serving as Assistant Professor at COER University since September 2023.</p>
            </div>
        </div>
    </section>

    <section id="frontend">
        <h2 class="section-title">Front-End Developer</h2>
        <div class="card">
            <img src="/images/frontendd.jpeg" alt="Frontend">
            <div class="content">
                <h2>Gulshan Kumar</h2>
                <p class="highlight">Front-End Developer | BCA Student</p>
                <p>Expertise in HTML, CSS, JavaScript, and Bootstrap.</p>
            </div>
        </div>
    </section>
    <section id="backend">
        <h2 class="section-title">Back-End Developer</h2>
        <div class="card">
            <img src="/images/backendd.jpeg" alt="Backend">
            <div class="content">
                <h2>Kartik Joshi</h2>
                <p class="highlight">Back-End Developer | BCA Student</p>
                <p>Expertise in Node.js, Express.js, MongoDB, and PostgreSQL.</p>
            </div>
        </div>
    </section>

    //--

    <%- include('partials/footer') %>

    <script>
        document.querySelectorAll(".sidebar a").forEach((anchor) => {
            anchor.addEventListener("click", function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute("href")).scrollIntoView({
                    behavior: "smooth",
                });
            });
        });

        const cards = document.querySelectorAll(".card");
        window.addEventListener("scroll", () => {
            cards.forEach((card) => {
                if (card.getBoundingClientRect().top < window.innerHeight - 100) {
                    card.style.opacity = "1";
                    card.style.transform = "translateY(0)";
                }
            });
        });
    </script>
</body>
</html>
